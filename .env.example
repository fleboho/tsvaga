# ============================================
# Tsvaga - Lost & Found MVP-1
# Required Environment Variables
# ============================================

# --- Database (PostgreSQL) ---
# Use Neon (free): https://console.neon.tech
# Or Railway, Supabase, etc.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Uploadthing (Image Uploads) ---
# Sign up: https://uploadthing.com
# Get token from dashboard → API Keys
UPLOADTHING_TOKEN=""

# --- NextAuth (Authentication) ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Set to your production URL in Vercel, or http://localhost:3000 for dev
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# Vercel Deployment Notes
# ============================================
# 
# All 4 variables above must be set in Vercel:
#   Project Settings → Environment Variables
#
# NEXTAUTH_URL must match your Vercel domain:
#   https://your-project.vercel.app
#
# DATABASE_URL from Neon dashboard (connection string)
#
# UPLOADTHING_TOKEN from Uploadthing dashboard
#   NOT the API key — use the full token (starts with ey...)
